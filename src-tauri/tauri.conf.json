{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "my-clipboard",
  "version": "0.1.0",
  "identifier": "com.lenovo.my-clipboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
  {
    "title": "Clipboard Manager",
    "width": 680,
    "height": 620,
    "decorations": true,
    "transparent": false,
    "resizable": true,
    "fullscreen": false
  }
],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}